NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Required for the autonomous reasoning loop.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Required for Google Maps business discovery.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_PAGE_LIMIT=1

# Required for LinkedIn company discovery through Google results.
SERPER_API_KEY=

# MongoDB persistence.
MONGODB_URI=mongodb://127.0.0.1:27017/ai_lead_generation_agent

# Agent defaults.
MAX_AGENT_ITERATIONS=12
DEFAULT_SEARCH_LIMIT=10
MAX_WEBSITES_TO_CRAWL=10
MAX_PAGES_PER_SITE=4
LOW_QUALITY_REVIEW_THRESHOLD=3.5
LOW_QUALITY_MIN_REVIEWS=5

# Network controls.
REQUEST_TIMEOUT_MS=15000
RETRY_ATTEMPTS=3
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Puppeteer can scrape only public LinkedIn company pages; no login bypass is used.
PUPPETEER_HEADLESS=true
PUPPETEER_NAVIGATION_TIMEOUT_MS=30000

# File outputs.
EXPORT_DIR=exports
LOG_LEVEL=info
