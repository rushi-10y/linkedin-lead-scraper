{
  "name": "erpnext-lead-scraper",
  "private": true,
  "version": "0.0.0",
  "description": "Production AI lead generation agent with autonomous tool calling",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "agent:dev": "node --watch src/index.js",
    "agent:start": "node src/index.js",
    "agent:check": "node --check src/index.js",
    "install:backend": "npm --prefix backend install",
    "install:admin": "npm --prefix backend/admin install",
    "install:api": "npm --prefix api install",
    "install:frontend": "npm --prefix frontend install",
    "install:ui": "npm --prefix frontend install",
    "install:all": "npm run install:backend && npm run install:admin && npm run install:api && npm run install:frontend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:backend:single": "npm --prefix backend run dev:single",
    "dev:admin": "npm --prefix backend/admin run dev",
    "dev:api": "npm --prefix api run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:ui": "npm --prefix frontend run dev",
    "dev:split": "concurrently -k -n frontend,backend -c magenta,green \"npm --prefix frontend run dev\" \"cd backend && npm run dev\"",
    "build:frontend": "npm --prefix frontend run build",
    "build:admin": "npm --prefix backend/admin run build",
    "build:frontend:watch": "npm --prefix frontend run build -- --watch",
    "dev:single": "concurrently -k -n frontend-build,backend -c magenta,green \"npm run build:frontend:watch\" \"npm run dev:backend:single\"",
    "dev": "npm run dev:split",
    "start:single": "npm run build:frontend && npm run build:admin && set NODE_ENV=production&& npm run start:backend",
    "start:backend": "npm --prefix backend run start",
    "start:api": "npm --prefix api run start",
    "start:frontend": "npm --prefix frontend run preview",
    "start:ui": "npm --prefix frontend run preview",
    "py:install": "python -m pip install -r requirements.txt",
    "py:scrape": "python scraper/leadScraper.py",
    "py:scheduler": "python scheduler/cronScheduler.py"
  },
  "dependencies": {
    "@langchain/core": "^1.1.46",
    "@langchain/textsplitters": "^1.0.1",
    "axios": "^1.13.5",
    "bottleneck": "^2.19.5",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.20.1",
    "openai": "^6.10.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.2",
    "puppeteer": "^24.40.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
